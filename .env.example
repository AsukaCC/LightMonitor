# ========== LightMonitor 环境变量示例 ==========
# 复制为 .env 后修改。勿提交真实 .env。

# 映射到宿主机的端口（compose 使用）
LIGHTMONITOR_PORT=8080

# 管理员登录（生产务必修改密码）
LIGHTMONITOR_ADMIN_USERNAME=admin
LIGHTMONITOR_ADMIN_PASSWORD=replace-with-a-strong-password

# 可选：探针连回监控服的固定基址（覆盖自动检测）
# 默认留空：安装命令 / SSH 安装会按你打开管理页时的 Host/Origin 自动生成
# 仅当管理端访问地址与探针可达地址不一致时再手动指定，例如：
# LIGHTMONITOR_PUBLIC_URL=http://203.0.113.10:8080
# LIGHTMONITOR_PUBLIC_URL=https://monitor.example.com
# LIGHTMONITOR_PUBLIC_URL=
# 可选：覆盖默认仓库 / 探针版本（SSH 安装与一键命令）
# LIGHTMONITOR_GITHUB_REPO=AsukaCC/LightMonitor
# LIGHTMONITOR_AGENT_VERSION=latest
# 管理后台更新源（官方 Docker 镜像和本地 Docker 构建均支持）
# LIGHTMONITOR_GITHUB_REPO=AsukaCC/LightMonitor

# 可选：docker-compose.release.yml 镜像
# LIGHTMONITOR_IMAGE=ghcr.io/asukacc/lightmonitor:latest

# 可选：旧版 SSH 密钥目录挂载（推荐在管理台“密钥管理”上传）
# Linux:   LIGHTMONITOR_SSH_DIR=/home/you/.ssh
# Windows: LIGHTMONITOR_SSH_DIR=C:\Users\you\.ssh

# 可选调优
# LIGHTMONITOR_OFFLINE_SECONDS=30
# LIGHTMONITOR_SESSION_TTL_HOURS=168
